int main(void) {
    int n; cin >> n;
    
    vector<int> v(n);
    for (int &x : v) cin >> x;
    
    ll max1 = INT_MIN;
    ll max2 = INT_MIN;
    
    for (int i = 0; i < n; i++) {
        if (v[i] > max1) {
            max2 = max1;
            max1 = v[i];
        } else if (v[i] < max1 && v[i] > max2) {
            max2 = v[i];
        }
    }
    
    if (max2 != INT_MIN) cout << max2 << endl;
    else cout << "NOT FOUND\n";
    
    return 0;
}
